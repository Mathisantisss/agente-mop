reportes/*.docx
reportes/*.pdf
!reportes/.gitkeep

# NOTA: chroma_db/ SÍ va al repo (vía Git LFS para el archivo grande)
# Si después migras a Pinecone, descomenta la siguiente línea:
# chroma_db/

