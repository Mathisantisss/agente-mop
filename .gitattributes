# Git LFS — archivos grandes de la base vectorial ChromaDB
# Necesario porque GitHub limita archivos a 100 MB sin LFS
chroma_db/*.sqlite3 filter=lfs diff=lfs merge=lfs -text
chroma_db/**/*.sqlite3 filter=lfs diff=lfs merge=lfs -text
chroma_db/**/*.bin filter=lfs diff=lfs merge=lfs -text
chroma_db/**/*.pickle filter=lfs diff=lfs merge=lfs -text

# Otros archivos binarios que puedan crecer
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# Forzar fin de línea LF en archivos Python (consistencia Win/Linux)
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf
