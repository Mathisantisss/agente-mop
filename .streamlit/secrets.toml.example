# ═══════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE SECRETS — Plantilla
# ═══════════════════════════════════════════════════════════════════
# Para DESARROLLO LOCAL:
#   1. Copia este archivo como `.streamlit/secrets.toml`
#   2. Rellena con tus valores reales
#   3. NUNCA lo subas a Git (ya está en .gitignore)
#
# Para STREAMLIT CLOUD:
#   1. Ve a https://share.streamlit.io
#   2. Tu app → Settings → Secrets
#   3. Pega el contenido (sin las líneas de comentario)
# ═══════════════════════════════════════════════════════════════════


# ─── Anthropic API Key (REQUERIDO) ─────────────────────────────────
# Obtén tu clave en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = "sk-ant-api03-..."


# ─── Contraseña de acceso (REQUERIDO en producción) ────────────────
# Esta contraseña la compartes con los miembros de tu empresa.
# Usa una cadena LARGA y aleatoria (mínimo 16 caracteres).
APP_PASSWORD = "cambia-esto-por-una-contraseña-larga-y-segura"
